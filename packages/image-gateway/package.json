{
    "name": "happy-image-gateway",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "bin": {
        "happy-image-gateway": "./dist/server.mjs",
        "happy-image-worker": "./dist/worker.mjs",
        "happy-image-native-codex": "./dist/nativeCodexCommand.mjs"
